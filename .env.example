LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5

# ---------- 腾讯云 Docker 部署（与 README 一致）----------
# 浏览器访问站点时的 origin，须与实际一致，多个用英文逗号分隔，例如：
# FRONTEND_ORIGINS=https://你的域名,http://服务器公网IP
# 本地 docker compose 试跑可写：FRONTEND_ORIGINS=http://127.0.0.1,http://localhost
#
# 仅在「前后端不同域」构建前端时需要；Docker 同源部署不必设置。
# VITE_API_BASE_URL=
