# 腾讯云 CVM / 轻量应用服务器：构建静态前端 + Nginx
FROM node:22-alpine AS web-build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig.json vite.config.ts index.html ./
COPY src ./src

# 与 Docker 内同源部署：不设 VITE_API_BASE_URL，走 /api 反代
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=web-build /app/dist /usr/share/nginx/html
COPY deployment/tencent/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
